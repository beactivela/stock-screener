{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "framework": null,
  "rewrites": [{ "source": "/((?!api).*)", "destination": "/index.html" }],
  "functions": {
    "api/*.js": { "maxDuration": 30 },
    "api/agents/**/*.js": { "maxDuration": 30 },
    "api/scan/*.js": { "maxDuration": 30 }
  }
}
