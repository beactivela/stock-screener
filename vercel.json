{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "framework": null,
  "rewrites": [
    { "source": "/api/:path*", "destination": "/api/catchall?path=:path*" },
    { "source": "/((?!api).*)", "destination": "/index.html" }
  ],
  "functions": {
    "api/catchall.js": { "maxDuration": 120 },
    "api/*.js": { "maxDuration": 30 },
    "api/agents/**/*.js": { "maxDuration": 30 },
    "api/scan/*.js": { "maxDuration": 30 }
  }
}
