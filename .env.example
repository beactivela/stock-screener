# Data: TradingView (ticker list, industry) + Yahoo (OHLC bars; no key required). Massive not used.

# Supabase — typical Hostinger VPS + Docker setup uses hosted Supabase as the database.
# Project Settings → API in the Supabase dashboard.
# Required for this app: SUPABASE_SERVICE_KEY (service role) so writes and scans work. RLS is ON for all public
# tables with no anon policies — the anon key cannot access app data via PostgREST.
# After schema.sql (+ learning migrations if used), run docs/supabase/migration-rls-and-api-hardening.sql once.
SUPABASE_URL=https://ksnneoomyrvmzukwxmqg.supabase.co
SUPABASE_SERVICE_KEY=your_service_role_key_here

# Financial Modeling Prep — unified experts sync (Congress disclosures + 13F probe). Apply docs/supabase/migration-fmp-congress.sql for DB tables.
# https://site.financialmodelingprep.com/developer/docs/stable
# FMP_API_KEY=
# FMP_CONGRESS_MAX_LIMIT=25
# If FMP congress fails but you still want StockCircle + WhaleWisdom to run: EXPERTS_ALLOW_FMP_CONGRESS_FAIL=1

# Quiver Quant — optional batched fetch of politician strategy returns + 90d trades (apply docs/supabase/migration-quiver-congress.sql + seed identities).
# Unified experts sync runs this after FMP congress when QUIVER_SYNC=1. Default: experts sync still succeeds if Quiver fails (set EXPERTS_ALLOW_QUIVER_FAIL=0 to make Quiver required).
# QUIVER_SYNC=1
# QUIVER_DELAY_MS=1200
# QUIVER_MAX_POLITICIANS=40
# QUIVER_BATCH_SIZE=8
# QUIVER_BATCH_PAUSE_MS=8000
# QUIVER_TRADE_LOOKBACK_DAYS=90
# Optional: CONGRESS_GOV_API_KEY — resolve FMP names to bioguide when no row in congress_politician_identity (api.congress.gov).

# StockCircle guru sync (overlap + /experts UI): retries help when many portfolios are scraped (429 / timeouts).
# STOCKCIRCLE_FETCH_RETRIES=3
# STOCKCIRCLE_INVESTOR_RETRIES=3
# STOCKCIRCLE_MAX_INVESTORS=40

# WhaleWisdom 13F filers (comma-separated /filer/ slugs). Default includes situational-awareness-lp (Leopold Aschenbrenner).
# Override or extend after exporting a manager list from Hedgefollow: npm run hedgefollow:map -- /path/to/export.csv
# WHALEWISDOM_FILER_SLUGS=situational-awareness-lp
# Optional JSON: manager display name → slug (copy server/experts/hedgefollowWhalewisdomOverrides.example.json)
# HEDGE_FOLLOW_WW_OVERRIDES_JSON=./data/hedgefollow-whalewisdom-overrides.json

# For migrations (preferred - avoids URL parsing issues with special chars in password):
# SUPABASE_PROJECT_REF=ksnneoomyrvmzukwxmqg
# SUPABASE_DB_PASSWORD=your_db_password
# Or full URI: DATABASE_URL=postgresql://postgres:[PASSWORD]@db.ksnneoomyrvmzukwxmqg.supabase.co:5432/postgres

# In-process 24h scan loop (optional). If you use VPS host cron OR Supabase pg_cron hitting /api/cron/run-scan,
# leave this OFF or you may double-schedule (server still throttles overlap, but triggers stack up).
# SCHEDULE_SCAN=1

# Scheduled scan HTTP trigger: REQUIRED when NODE_ENV=production for POST /api/cron/scan and POST /api/cron/run-scan.
# Use a long random value; store only on the VPS / Supabase job config, never in git.
# Send as: Authorization: Bearer <CRON_SECRET> or header x-cron-secret: <CRON_SECRET>
# VPS: scripts/trigger-scheduled-scan.sh + deploy/host-cron.example. Supabase: pg_net → https://stocks.scaleagent.org/api/cron/run-scan
# CRON_SECRET=your_random_secret_here
# POST /api/cron/experts-sync from the /experts UI (same-origin) without pasting the secret when NODE_ENV=production.
# Docker Compose sets CRON_ALLOW_EXPERTS_BROWSER_SYNC=1; set to 0 to require Bearer for experts sync too.
# CRON_ALLOW_EXPERTS_BROWSER_SYNC=1
# Host crontab curl target (loopback + docker-published port). App reads this for GET /api/cron/status hints.
# CRON_BASE_URL=http://127.0.0.1:8080

# Optional: port when running API-only (npm run server). Dev uses 5174 via npm run dev.
# PORT=3001

# Docker / Hostinger VPS: use docker compose (see docs/DEPLOY_HOSTINGER_VPS.md).
# Leave VITE_API_URL unset so the built UI uses same-origin /api.
# Hostname for Traefik router rule Host(`...`) + Let’s Encrypt. DNS must point at the VPS.
TRAEFIK_HOST=stocks.scaleagent.org
# Contact email for Let’s Encrypt (required by the bundled traefik service in docker-compose.yml).
# ACME_EMAIL=you@yourdomain.com
# Published port for direct access / cron (avoid 3001/8080 if other stacks use them on the same VPS)
# HOST_PORT=8090

# Uptime Kuma (docker compose service uptime-kuma): host port for the Kuma UI (container listens on 3001).
# After `docker compose up -d`, open http://127.0.0.1:${KUMA_PORT:-3001} and create the admin user.
# Internal monitor URL from Kuma: http://stock-screener:3000/api/health
# KUMA_PORT=3001

# Rare: point the built UI at a different API origin (default is same-origin /api).
# VITE_API_URL=https://your-api.example.com

# Expert overlap — AI (POST /api/experts/ai-insights, POST /api/experts/consensus-buys-ai).
# Ollama is preferred when OLLAMA_API_KEY is set (default model minimax-m2.7:cloud). Else OpenRouter when OPENROUTER_API_KEY is set (default gemini-3-flash-preview:cloud).
# Ollama Cloud: https://ollama.com/settings/keys — then default base URL is https://ollama.com/v1 (OpenAI-compatible).
# OLLAMA_API_KEY=...
# Optional: OLLAMA_BASE_URL=http://127.0.0.1:11434/v1 (local Ollama; if unset with OLLAMA_API_KEY, defaults to https://ollama.com/v1)
# Optional: EXPERTS_INSIGHTS_MODEL — Ollama default minimax-m2.7:cloud; OpenRouter default gemini-3-flash-preview:cloud when unset per provider
# Optional: EXPERTS_INSIGHTS_PROVIDER=ollama | openrouter | anthropic | openai (force provider when you have multiple keys)
# https://openrouter.ai/keys
# OPENROUTER_API_KEY=sk-or-v1-...
# If OpenRouter returns empty text, set these (server defaults: Referer http://127.0.0.1:5174, Title stock-screener).
# OPENROUTER_HTTP_REFERER=https://your-domain.example OPENROUTER_APP_TITLE=stock-screener
# EXPERTS_AI_DEBUG=1 — log LLM message shape + consensus narrative preview (dev/troubleshooting).
# EXPERTS_CONSENSUS_PROMPT_LOG=1 — temporary: log + API/UI include first-call char counts and raw system+user text (copy-paste to another LLM) for consensus-buys-ai.
# Consensus tab: EXPERTS_CONSENSUS_BUYS_MAX_TOKENS (default 8192, max 16384) — completion budget (Gemini counts reasoning+text); input is slimmed separately.
# If the model still stops mid-sentence (finish_reason=length), server auto-requests continuations: EXPERTS_CONSENSUS_BUYS_MAX_CONTINUATIONS (default 2, max 4; set 0 to disable).
# Context guard: EXPERTS_LLM_MAX_JSON_CHARS (default 100000) caps the stringified slim digest; per-row buyer/seller refs: EXPERTS_CONSENSUS_LLM_MAX_EXPERT_REFS_PER_ROW (default 8).
# Row caps (defaults): EXPERTS_CONSENSUS_LLM_MAX_MULTI/SINGLE/SELLS/MIXED/LARGE_POSITIONS (25/25/25/20/25), EXPERTS_CONSENSUS_LLM_MAX_EXPERT_NAME_CHARS (96).
# Overlap digest: EXPERTS_MOVES_DIGEST_TOP_N (default 30), EXPERTS_MOVES_LLM_MAX_CONGRESS_LINES (default 12).
# If consensus narrative still cites symbols not in the table after one retry: EXPERTS_CONSENSUS_REJECT_ON_HALLUCINATION=1 (API error instead of returning text).

# Minervini AI coach (in-app chat, Claude). Get key from console.anthropic.com.
# Optional: ANTHROPIC_CHAT_MODEL=claude-3-5-sonnet-20241022 (or another model id)
# ANTHROPIC_API_KEY=sk-ant-...
# Multi-agent dialogue can still use AGENT_DIALOGUE_PROVIDER + Anthropic/OpenAI (separate from expert snapshot).
# Optional override for Anthropic-only snapshot: EXPERTS_INSIGHTS_MODEL=claude-3-5-haiku-20241022

# Multi-agent conversation LLMs (Marcus + specialists)
# AGENT_DIALOGUE_PROVIDER=anthropic
# AGENT_DIALOGUE_MODEL_STRONG=claude-sonnet-4-5
# AGENT_DIALOGUE_MODEL_FAST=claude-3-5-haiku-20241022
# AGENT_DIALOGUE_MAX_TOKENS=800
# AGENT_DIALOGUE_TIMEOUT_MS=30000
# OPENAI_API_KEY=sk-...

# TradingAgents page (/tradingagents): Python runner uses these (optional).
# Defaults: gpt-4o + gpt-4o-mini, 300s per LLM HTTP call, Chat Completions (not Responses API).
# TRADINGAGENTS_DEEP_MODEL=gpt-4o
# TRADINGAGENTS_QUICK_MODEL=gpt-4o-mini
# TRADINGAGENTS_LLM_TIMEOUT_SECONDS=300
# TRADINGAGENTS_LLM_MAX_RETRIES=2
# Server (Node) kills the Python runner after this many ms. Default 45m. Example: 3600000 = 60m
# TRADINGAGENTS_RUN_TIMEOUT_MS=2700000
# Progress line every N seconds while the graph runs (0 = disable)
# TRADINGAGENTS_HEARTBEAT_SECONDS=25
# Run market/social/news/fundamentals analyst tool-loops in parallel (LangGraph Send); then joins before Bull researcher.
# TRADINGAGENTS_PARALLEL_ANALYSTS=1
# Cap debate / risk loops (defaults in vendor config are 1 each; lower = faster, rougher)
# TRADINGAGENTS_MAX_DEBATE_ROUNDS=1
# TRADINGAGENTS_MAX_RISK_DISCUSS_ROUNDS=1
# Keep one Python process warm: run `.venv-tradingagents/bin/python -u scripts/tradingagents/worker_stdio.py` and set:
# TRADINGAGENTS_STDIO_WORKER=1
# (Node multiplexes stdin/out; one in-flight job globally — second run returns 503 until the first completes.)
# Default 1 = OpenAI Responses API (recommended). Set 0 only to force Chat Completions.
# TRADINGAGENTS_OPENAI_USE_RESPONSES_API=1

# AI Portfolio (/ai-portfolio): daily paper portfolios call the LLM for trade ideas.
# Default router is OpenRouter (same OPENROUTER_API_KEY as experts). Override provider only if you know you need direct Anthropic/OpenAI or local Ollama.
# AI_PORTFOLIO_LLM_PROVIDER=openrouter
# Per-manager OpenRouter model slugs (optional; defaults below match OpenRouter catalog):
# AI_PORTFOLIO_MODEL_CLAUDE=anthropic/claude-sonnet-4.6
# AI_PORTFOLIO_MODEL_GPT=openai/gpt-5.4
# AI_PORTFOLIO_MODEL_GEMINI=google/gemini-2.0-flash-001
# AI_PORTFOLIO_MODEL_DEEPSEEK=deepseek/deepseek-v3.2
# Scheduler (optional): market checkpoint cron (Central Time)
# AI_PORTFOLIO_SCHEDULE_ENABLED=1
# AI_PORTFOLIO_SCHEDULE_TIMEZONE=America/Chicago
# AI_PORTFOLIO_SCHEDULE_TIMES=09:00,11:00,13:00,14:30
# AI_PORTFOLIO_SCHEDULE_TICK_MS=60000
# OpenRouter returns billed USD on `usage.cost`; the app sums it per calendar day for the AI Portfolio cost chart (persisted in saved portfolio state).

# ── VPS / Docker: deploy status + “Build & deploy” header (production build only)
# Compares GIT_COMMIT baked into the image with the default branch on GitHub.
# GITHUB_REPO=your-org/stock-screener
# GITHUB_DEFAULT_BRANCH=main
# GITHUB_TOKEN=ghp_...   # PAT: repo read + Actions workflow dispatch (fine-grained: Contents read, Actions write)
# Optional separate header trigger secret (else CRON_SECRET is accepted):
# DEPLOY_SECRET=long_random_string
# GITHUB_WORKFLOW_FILE=docker-publish.yml
# GIT_COMMIT is injected at docker build (Dockerfile ARG); leave unset unless debugging.

# Optional: [virattt/ai-hedge-fund](https://github.com/virattt/ai-hedge-fund) web UI (cloned under ./ai-hedge-fund; Vite dev on 5175 while stock-screener uses 5174).
# VITE_AI_HEDGE_FUND_URL=http://127.0.0.1:5175

# AI Hedge Fund (Python) — bars/fundamentals + FMP proxy (see docs/ai-hedge-fund-market-data.md). FMP_API_KEY stays here; ai-hedge-fund uses STOCK_SCREENER_API_BASE only.
# STOCK_SCREENER_API_BASE=http://127.0.0.1:5174
# HEDGE_FUND_MARKET_DATA=composite
