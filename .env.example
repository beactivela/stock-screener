# Massive API key (get from massive.com). Required for bars, ETF constituents, dividends.
# Never commit .env or expose the key in the frontend.
MASSIVE_API_KEY=your_api_key_here

# Optional: run full VCP scan every 24 hours when the server is running
# SCHEDULE_SCAN=1

# Optional: API server port (default 3001)
# PORT=3001
