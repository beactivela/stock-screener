# Data: TradingView (ticker list, industry) + Yahoo (OHLC bars; no key required). Massive not used.

# Supabase — typical Hostinger VPS + Docker setup uses hosted Supabase as the database.
# Project Settings → API in the Supabase dashboard.
# Recommended for this app: service_role on the server (SUPABASE_SERVICE_KEY) so writes and scans work as shipped.
# Anon + RLS only if you have explicitly designed policies; do not swap keys casually.
# Vercel: same vars in Project → Environment Variables (no .env on the host).
SUPABASE_URL=https://ksnneoomyrvmzukwxmqg.supabase.co
SUPABASE_SERVICE_KEY=your_service_role_key_here

# For migrations (preferred - avoids URL parsing issues with special chars in password):
# SUPABASE_PROJECT_REF=ksnneoomyrvmzukwxmqg
# SUPABASE_DB_PASSWORD=your_db_password
# Or full URI: DATABASE_URL=postgresql://postgres:[PASSWORD]@db.ksnneoomyrvmzukwxmqg.supabase.co:5432/postgres

# In-process 24h scan loop (optional). If you use VPS host cron OR Supabase pg_cron hitting /api/cron/run-scan,
# leave this OFF or you may double-schedule (server still throttles overlap, but triggers stack up).
# SCHEDULE_SCAN=1

# Scheduled scan HTTP trigger: REQUIRED when NODE_ENV=production for POST /api/cron/scan and POST /api/cron/run-scan.
# Use a long random value; store only on the VPS / Supabase job config, never in git.
# Send as: Authorization: Bearer <CRON_SECRET> or header x-cron-secret: <CRON_SECRET>
# VPS: scripts/trigger-scheduled-scan.sh + deploy/host-cron.example. Supabase: pg_net → https://your-domain/api/cron/run-scan
# CRON_SECRET=your_random_secret_here

# Optional: port when running API-only (npm run server). Dev uses 5173 via npm run dev.
# PORT=3001

# Docker / Hostinger VPS: use docker compose (see docs/DEPLOY_HOSTINGER_VPS.md).
# Leave VITE_API_URL unset so the built UI uses same-origin /api.
# Remove VERCEL from .env on the VPS — compose sets an empty override so file writes work under /app/data.
# Hostname for Traefik (Hostinger template). DNS A record must point at the VPS for HTTPS.
# TRAEFIK_HOST=screener.yourdomain.com
# Published port for direct access / cron (avoid 3001/8080 if other stacks use them on the same VPS)
# HOST_PORT=8090

# Vercel only: set in Vercel project env if the UI should call a separate API host
# VITE_API_URL=https://your-api.railway.app

# Minervini AI coach (in-app chat, Claude). Get key from console.anthropic.com.
# Optional: ANTHROPIC_CHAT_MODEL=claude-3-5-sonnet-20241022 (or another model id)
# ANTHROPIC_API_KEY=sk-ant-...

# Multi-agent conversation LLMs (Marcus + specialists)
# AGENT_DIALOGUE_PROVIDER=anthropic
# AGENT_DIALOGUE_MODEL_STRONG=claude-sonnet-4-5
# AGENT_DIALOGUE_MODEL_FAST=claude-3-5-haiku-20241022
# AGENT_DIALOGUE_MAX_TOKENS=800
# AGENT_DIALOGUE_TIMEOUT_MS=30000
# OPENAI_API_KEY=sk-...

# ── VPS / Docker: deploy status + “Build & deploy” header (production build only)
# Compares GIT_COMMIT baked into the image with the default branch on GitHub.
# GITHUB_REPO=your-org/stock-screener
# GITHUB_DEFAULT_BRANCH=main
# GITHUB_TOKEN=ghp_...   # PAT: repo read + Actions workflow dispatch (fine-grained: Contents read, Actions write)
# Optional separate header trigger secret (else CRON_SECRET is accepted):
# DEPLOY_SECRET=long_random_string
# GITHUB_WORKFLOW_FILE=docker-publish.yml
# GIT_COMMIT is injected at docker build (Dockerfile ARG); leave unset unless debugging.
