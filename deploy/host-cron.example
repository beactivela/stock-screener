# Example: VPS host cron calling the Docker-mapped port (no TLS on loopback).
# 1. Copy to /etc/cron.d/stock-screener (or use root crontab).
# 2. Create a root-only env file, e.g. /opt/stock-screener/.cron-env:
#      export CRON_SECRET='your-long-random-secret'
#      export CRON_BASE_URL='http://127.0.0.1:8090'
#    (must match HOST_PORT in server .env / docker-compose; 8080 and 8090 are common.)
# 3. chmod 600 /opt/stock-screener/.cron-env
# 4. chmod +x /opt/stock-screener/scripts/trigger-scheduled-scan.sh
#    chmod +x /opt/stock-screener/scripts/trigger-scheduled-refresh-bars.sh
#
# America/Chicago = US Central (CST/CDT). All times below are local wall clock.
# CRON_TZ applies to every line in this file until another CRON_TZ.
CRON_TZ=America/Chicago
#
# 4:38 PM Mon–Fri — warm bars_cache (Yahoo daily OHLC) for the full scan universe before the scan.
# (5th field 1-5 = weekdays; US market closed Sat/Sun.)
38 16 * * 1-5 root . /opt/stock-screener/.cron-env && /opt/stock-screener/scripts/trigger-scheduled-refresh-bars.sh >> /var/log/stock-screener-cron.log 2>&1
#
# 5:12 PM Mon–Fri — full VCP scan (same as UI "Run scan").
12 17 * * 1-5 root . /opt/stock-screener/.cron-env && /opt/stock-screener/scripts/trigger-scheduled-scan.sh >> /var/log/stock-screener-cron.log 2>&1
#
# Alternate (one live Hostinger install): source the repo .env instead of .cron-env — still set CRON_BASE_URL + CRON_SECRET there.
# 38 16 * * 1-5 root /bin/bash -lc 'set -a; source /opt/stock-screener/.env; set +a; exec /opt/stock-screener/scripts/trigger-scheduled-refresh-bars.sh' >> /var/log/stock-screener-cron.log 2>&1
# 12 17 * * 1-5 root /bin/bash -lc 'set -a; source /opt/stock-screener/.env; set +a; exec /opt/stock-screener/scripts/trigger-scheduled-scan.sh' >> /var/log/stock-screener-cron.log 2>&1

# Do not enable this AND SCHEDULE_SCAN=1 in the container, or Supabase pg_cron hitting the same
# endpoint, unless you accept possible double-runs; the app skips if a scan is already running / cooldown.
